<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_1">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_profile"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="32dp"
        app:cardBackgroundColor="#44000000"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/kepala_1"
            android:scaleType="centerCrop"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/ll_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@id/cv_profile"
        app:layout_constraintBottom_toBottomOf="@id/cv_profile"
        app:layout_constraintStart_toEndOf="@id/cv_profile"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_player_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RIO - Lv.10 Novice"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:shadowColor="#000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="2"/>

            <TextView
                android:id="@+id/tv_coins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰 0"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:textSize="14sp"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="1"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginTop="4dp">
            <ProgressBar
                android:id="@+id/pb_hp"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:progress="67"
                android:progressTint="#FF3333"
                android:backgroundTint="#66000000" />
            <TextView
                android:id="@+id/tv_hp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="67 / 100 HP"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="1"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginTop="4dp">
            <ProgressBar
                android:id="@+id/pb_mp"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:progress="43"
                android:progressTint="#3399FF"
                android:backgroundTint="#66000000" />
            <TextView
                android:id="@+id/tv_mp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="43 / 100 MP"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="1"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginTop="4dp">
            <ProgressBar
                android:id="@+id/pb_exp"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:progress="88"
                android:progressTint="#33FF33"
                android:backgroundTint="#66000000" />
            <TextView
                android:id="@+id/tv_exp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="88 / 100 EXP"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="1"/>
        </FrameLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/img_character"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/char_1"
        app:layout_constraintTop_toBottomOf="@id/ll_status"
        app:layout_constraintBottom_toTopOf="@id/ll_menu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/ll_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_main"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="⚔️ MAIN QUEST"
            android:textColor="#000000"
            android:backgroundTint="#FFD700"
            app:cornerRadius="8dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_side"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🛡️ SIDE QUEST"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            app:cornerRadius="8dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_daily"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="⏳ DAILY QUEST"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            app:cornerRadius="8dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_shop"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🛒 TOKO"
            android:textColor="#FFFFFF"
            android:backgroundTint="#9C27B0"
            app:cornerRadius="8dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>